# Database
MONGODB_URI=mongodb://localhost:27017/splitwise_clone

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
